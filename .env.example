# ============================================================
# Variables de entorno requeridas
# Copia este archivo a .env.local y rellena los valores
# NUNCA commitees .env.local ni .env.production.local
# ============================================================

# Sanity CMS
# Project ID: se encuentra en sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Dataset: "development" para dev, "production" para prod
NEXT_PUBLIC_SANITY_DATASET=development
# Token con permisos de escritura (sanity.io/manage > API > Tokens)
SANITY_WRITE_TOKEN=

# Resend (envío de emails de leads)
# Obtener en resend.com/api-keys
RESEND_API_KEY=
# Email remitente verificado en Resend
RESEND_FROM=noreply@tudominio.com
# Email donde llegan los leads
LEADS_EMAIL=info@tudominio.com

# Mapbox (mapas de propiedades)
# Obtener en account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN=
